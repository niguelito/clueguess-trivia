/**
 * Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for all user-generated content (Decks and Trivia Cards), 
 * while providing global read access to reference data (Categories). It prioritizes "Authorization Independence" 
 * by expecting key identifiers like owner IDs and parent IDs to be denormalized directly onto documents.
 * 
 * Data Structure:
 * - /categories/{categoryId}: Global, read-only reference data for all users.
 * - /users/{userId}: Private user root documents.
 * - /users/{userId}/decks/{deckId}: Private decks owned by the specific user.
 * - /users/{userId}/decks/{deckId}/triviaCards/{cardId}: Private trivia cards belonging to a user's deck.
 * 
 * Key Security Decisions:
 * 1. Ownership via Path: Access to user data is primarily restricted by comparing the {userId} in the 
 *    Firestore path to the authenticated user's UID (request.auth.uid).
 * 2. Denormalization for Integrity: To ensure data stays organized and secure, write operations 
 *    validate that internal fields (like deckId) match the path parameters.
 * 3. Prototyping Flexibility: These rules enforce WHO can access the data but do NOT enforce the 
 *    specific schema or data types of the content fields (e.g., card answers, deck descriptions) 
 *    to allow for rapid development.
 * 4. Resource Existence: Destructive operations (update, delete) explicitly verify the document 
 *    exists before proceeding to prevent orphaned requests.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document exists for state changes. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for global trivia categories. Publicly readable, backend managed.
     * @path /categories/{categoryId}
     * @allow (get, list) for any user.
     * @deny (create, update, delete) for all users via client SDK.
     * @principle Public Read with Restricted Writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the user root document.
     * @path /users/{userId}
     * @allow (create, get, list, update) if the user matches the document ID.
     * @deny (delete) users cannot delete their own root record via client.
     * @principle Self-creation and strict ownership of user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Rules for user-owned trivia decks.
     * @path /users/{userId}/decks/{deckId}
     * @allow (all) if the authenticated user is the {userId} in the path.
     * @deny (all) if the userId does not match request.auth.uid.
     * @principle Path-based authorization and relational integrity (id consistency).
     */
    match /users/{userId}/decks/{deckId} {
      allow get, list: if isOwner(userId);
      // Ensure the internal 'id' (if provided) matches the deckId in the path for consistency
      allow create: if isOwner(userId) && (request.resource.data.id == deckId);
      // Ensure the 'id' field remains immutable during updates
      allow update: if isExistingOwner(userId) && (request.resource.data.id == resource.data.id);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for trivia cards within a specific deck.
       * @path /users/{userId}/decks/{deckId}/triviaCards/{triviaCardId}
       * @allow (all) if the user owns the parent deck.
       * @deny (create) if the card's deckId does not match the path's deckId.
       * @principle Nested ownership and relational integrity (deckId consistency).
       */
      match /triviaCards/{triviaCardId} {
        allow get, list: if isOwner(userId);
        // Force the card to be associated with the deck identified in the path
        allow create: if isOwner(userId) && (request.resource.data.deckId == deckId);
        // Prevent moving cards between decks by keeping deckId immutable
        allow update: if isExistingOwner(userId) && (request.resource.data.deckId == resource.data.deckId);
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}